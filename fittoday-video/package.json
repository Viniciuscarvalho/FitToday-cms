{
  "name": "fittoday-video",
  "version": "1.0.0",
  "description": "FitToday CMS Tutorial Video Series built with Remotion",
  "scripts": {
    "studio": "remotion studio src/index.ts",
    "render": "remotion render src/index.ts",
    "render:all": "for comp in 01-Intro 02-Dashboard 03-Treinos 04-Alunos 05-Mensagens 06-Analytics 07-Financeiro 08-Configuracoes 09-Outro; do npx remotion render src/index.ts $comp out/$comp.mp4; done",
